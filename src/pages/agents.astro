---
import '../styles/global.css';
import Layout from "../layouts/Layout.astro";
import PBImage from "../components/PBImage.astro";
import { getAgents } from "../js/backend.mjs";

const agents = await getAgents();
---

<Layout titre="Agents">
    <h1 class="text-2xl text-center mb-2">Nos Agents</h1>
    <p class="text-center mb-12">Découvrez notre équipe d'agents immobiliers</p>
    
    <div class="grid grid-cols-1 md:grid-cols-1 gap-8 max-w-7xl mx-auto px-4 mb-12">
        {agents.map((agent) => (
            <div class="bg-white rounded-lg shadow-md p-10 hover:shadow-lg transition-shadow flex flex-col">
                {agent.photo && (
                    <div class="mb-6 flex justify-center">
                        <PBImage record={agent} imageField={agent.photo} />
                    </div>
                )}
                <h3 class="text-2xl font-semibold text-center mb-4" style="color: #334155;">
                    {agent.prenom} {agent.nom}
                </h3>
                {agent.email && (
                    <p class="text-gray-600 text-center mb-2">
                        <span class="font-medium">Email:</span> {agent.email}
                    </p>
                )}
                {agent.telephone && (
                    <p class="text-gray-600 text-center mb-2">
                        <span class="font-medium">Tél:</span> {agent.telephone}
                    </p>
                )}
                {agent.specialite && (
                    <p class="text-gray-500 text-center text-sm mt-4 italic mb-6">
                        {agent.specialite}
                    </p>
                )}
                <div class="mt-auto text-center">
                    <a href={`/agents/${agent.id}`} class="inline-block px-6 py-3 text-white rounded-lg transition-colors duration-200 shadow-md hover:shadow-lg" style="background-color: #334155; text-decoration: none;">
                        Voir les offres
                    </a>
                </div>
            </div>
        ))}
    </div>
</Layout>
